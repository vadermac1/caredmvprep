# ─────────────────────────────────────────────────────────────────────────────
# CAREDMVPrep — Environment Variables
# Copy this file to .env.local and fill in every value before starting the app.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Resend (transactional email) ──────────────────────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_...

# ── Stripe ───────────────────────────────────────────────────────────────────
# Use sk_test_... and price_test_... during development.
# Switch to sk_live_... and price_live_... for production.
# Found in: dashboard.stripe.com → Developers → API Keys

STRIPE_SECRET_KEY=sk_test_...

# Found in: dashboard.stripe.com → Developers → Webhooks → your endpoint → Signing secret
# Local dev: run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Price IDs ──────────────────────────────────────────────────────────
# Create one Product per line below in the Stripe Dashboard, then add two Prices
# (monthly recurring + annual recurring) to each.
# The Price ID format is: price_...

# Driver's License
STRIPE_PRICE_DMV_MONTHLY=price_...
STRIPE_PRICE_DMV_ANNUAL=price_...

# Motorcycle License
STRIPE_PRICE_MOTO_MONTHLY=price_...
STRIPE_PRICE_MOTO_ANNUAL=price_...

# CDL Core (General Knowledge)
STRIPE_PRICE_CDL_MONTHLY=price_...
STRIPE_PRICE_CDL_ANNUAL=price_...

# CDL HazMat Endorsement add-on
STRIPE_PRICE_HAZMAT_MONTHLY=price_...
STRIPE_PRICE_HAZMAT_ANNUAL=price_...

# CDL Tank Vehicles Endorsement add-on
STRIPE_PRICE_TANKER_MONTHLY=price_...
STRIPE_PRICE_TANKER_ANNUAL=price_...

# CDL Doubles & Triples Endorsement add-on
STRIPE_PRICE_DOUBLES_MONTHLY=price_...
STRIPE_PRICE_DOUBLES_ANNUAL=price_...

# CDL School Bus Endorsement
STRIPE_PRICE_SCHOOL_BUS_MONTHLY=price_...
STRIPE_PRICE_SCHOOL_BUS_ANNUAL=price_...

# CDL Passenger Endorsement
STRIPE_PRICE_PASSENGER_MONTHLY=price_...
STRIPE_PRICE_PASSENGER_ANNUAL=price_...

# ── PostHog (analytics) ───────────────────────────────────────────────────────
# Found in: app.posthog.com → Project → Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Sentry (error monitoring) ─────────────────────────────────────────────────
# Found in: sentry.io → Project → Settings → SDK Setup
NEXT_PUBLIC_SENTRY_DSN=https://...@o....ingest.sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=caredmvprep
