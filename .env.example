# ─────────────────────────────────────────────────────────────────────────────
# CAREDMVPrep — Environment Variables
# Copy to .env.local and fill in every value. NEVER commit .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Stripe ───────────────────────────────────────────────────────────────────
# Use sk_test_... in development; sk_live_... in production.
# Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...

# Dashboard → Developers → Webhooks → your endpoint → Signing secret
# Local dev: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Price IDs ──────────────────────────────────────────────────────────
# Create products in Stripe Dashboard, then add the Price IDs below.
# MONTHLY prices → recurring, billed each month
# ONETIME prices → one-time payment (single charge, no recurrence)

# Driver's License — $12/mo recurring OR $29 one-time (3 months)
STRIPE_PRICE_DMV_MONTHLY=price_...
STRIPE_PRICE_DMV_ONETIME=price_...

# Motorcycle License — $12/mo recurring OR $29 one-time (3 months)
STRIPE_PRICE_MOTO_MONTHLY=price_...
STRIPE_PRICE_MOTO_ONETIME=price_...

# CDL Core — $19/mo recurring OR $49 one-time (6 months)
STRIPE_PRICE_CDL_MONTHLY=price_...
STRIPE_PRICE_CDL_ONETIME=price_...

# CDL HazMat Endorsement — $19 one-time (6 months) — no recurring option
STRIPE_PRICE_HAZMAT=price_...

# CDL Tank Vehicles Endorsement — $15 one-time (6 months)
STRIPE_PRICE_TANKER=price_...

# CDL Doubles & Triples Endorsement — $15 one-time (6 months)
STRIPE_PRICE_DOUBLES=price_...

# ── PostHog (analytics) ───────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Sentry (error monitoring) ─────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@o....ingest.sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=caredmvprep
